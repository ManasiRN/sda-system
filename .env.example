# ============================================
# SDA System - Environment Configuration Template
# ============================================
# Copy to .env and fill in real values.
# NEVER commit .env to version control.
# Fields marked REQUIRED must be set before docker-compose up.

# Deployment
ENVIRONMENT=production
LOG_LEVEL=INFO

# ── PostgreSQL (REQUIRED in production) ─────────────────────────────────────
POSTGRES_DB=sda_db
POSTGRES_USER=sda_user
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password

# Database DSN (constructed from above by docker-compose; override for external DB)
DATABASE_URL=postgresql://sda_user:CHANGE_ME@postgres:5432/sda_db
DATABASE_POOL_SIZE=20

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=300

# ── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── API authentication (REQUIRED in production) ──────────────────────────────
API_KEY_REQUIRED=true
# openssl rand -hex 32
API_KEY_SALT=CHANGE_ME_64_hex_chars
# JSON array of initial API keys; rotate via POST /admin/api-keys after first deploy
API_KEYS=[]

# ── Admin endpoints (REQUIRED in production) ─────────────────────────────────
# openssl rand -hex 32
ADMIN_API_KEY=CHANGE_ME_strong_random_secret

# ── CORS (set to your frontend origin(s) in production) ──────────────────────
# Comma-separated or JSON array: https://dashboard.example.com,https://app.example.com
CORS_ORIGINS=

# ── Monitoring ───────────────────────────────────────────────────────────────
# Flower basic-auth: user:password  (change from default before exposing port 5555)
FLOWER_BASIC_AUTH=admin:CHANGE_ME_flower_password

# ── TLE ingestion ────────────────────────────────────────────────────────────
CELESTRAK_URL=https://celestrak.org/NORAD/elements/gp.php?GROUP=active
# Optional comma-separated fallback URLs tried if primary fails:
TLE_FALLBACK_URLS=
TLE_FETCH_INTERVAL_HOURS=6
TLE_VALID_DAYS=7
# Health check degrades if last ingest is older than this many hours:
TLE_STALE_ALERT_HOURS=24

# ── Propagation ──────────────────────────────────────────────────────────────
PROPAGATION_STEP_SECONDS=10
PROPAGATION_DAYS=7
REFINEMENT_PRECISION_SECONDS=1

# ── Pass Detection ───────────────────────────────────────────────────────────
MIN_ELEVATION_DEG=10.0
MIN_PASS_DURATION_SECONDS=5
EARTH_RADIUS_KM=6371.0

# ── Scheduling ───────────────────────────────────────────────────────────────
SCHEDULER_GREEDY_WEIGHT=elevation_x_duration
ORTOOLS_TIME_LIMIT_SECONDS=30

# ── Performance ──────────────────────────────────────────────────────────────
BATCH_SIZE=100
MAX_WORKERS=4
